# =========================================================================
# Astrokat — Environment Configuration
# =========================================================================
# Copy this file to .env and fill in your values.

# ── Chat Adapters ────────────────────────────────────────────────────────
# Comma-separated list of platforms to connect to.
# Options: discord, fluxer  (or both: discord,fluxer)
ADAPTERS=discord,fluxer

# Discord Bot Token (required if ADAPTERS includes "discord")
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Fluxer Bot Token (required if ADAPTERS includes "fluxer")
FLUXER_TOKEN=your_fluxer_token_here

# Fluxer API URL (only needed for self-hosted Fluxer instances)
# Defaults to the official Fluxer API: https://api.fluxer.app
# Set this to your custom Fluxer instance API URL to self-host.
FLUXER_API_URL=https://api.your-fluxer-instance.com

# Fluxer Web URL (only needed for self-hosted Fluxer instances)
# Defaults to the official Fluxer web app: https://web.fluxer.app
# Used for clickable channel/message links in the role command output.
FLUXER_WEB_URL=https://web.your-fluxer-instance.com

# Discord Application ID (only needed for deploying slash commands)
# Run: npm run deploy
DISCORD_ID=your_discord_application_id_here
# ── Command Prefix ──────────────────────────────────────────────────────────
# Default prefix used when a guild hasn't set a custom one via !settings prefix.
# Change this if another bot on your server uses "!" and you want to avoid
# conflicts out of the box. Each guild can still set their own via !settings.
DEFAULT_PREFIX=!

# ── Reminder Storage ─────────────────────────────────────────────────────
# Leave DATABASE_URL unset/empty → uses SQLite (embedded, zero setup).
# Set DATABASE_URL → uses PostgreSQL (required for multi-instance deployments).
DATABASE_URL=postgresql://user:password@host:5432/astrokat

# ── Bot Operators ────────────────────────────────────────────────────────
# Comma-separated list of user IDs that can run system-level commands
# (set status, and in the future start/stop/deploy the bot).
# Only operators can invoke commands in the "system" category.
# Example: BOT_OPERATOR_IDS=123456789012345678,987654321098765432
BOT_OPERATOR_IDS=your_user_id_here

# ── Rate Limiting ────────────────────────────────────────────────────────
# Maximum number of commands a single user can run per window (per guild).
RATE_LIMIT_USER_MAX=10

# Maximum number of commands the entire guild can run per window.
RATE_LIMIT_GUILD_MAX=100

# Time window for rate limit counters, in milliseconds (default: 60000 = 1 min).
RATE_LIMIT_WINDOW_MS=60000